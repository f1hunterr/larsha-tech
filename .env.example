# ── Admin dashboard password ─────────────────────────────────────────────────
# Change this before deploying. Access admin at http://your-server/admin
ADMIN_PASSWORD=changeme

# ── SQLite database file path ─────────────────────────────────────────────────
# The leads.db file will be created here. Mount a Docker volume to this path.
DB_PATH=/data/leads.db

# ── Frontend env vars (set at build time) ────────────────────────────────────
# Formspree form ID — get it from formspree.io after creating a form
VITE_FORMSPREE_ID=your_formspree_id_here

# Backend API URL — only needed when self-hosting (leave empty for GitHub Pages)
VITE_API_URL=http://your-server:4000
